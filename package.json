{
  "name": "chikku-parser",
  "version": "0.3.5",
  "description": "Desktop app for viewing, combining, and transforming CSV data",
  "main": "dist/main.bundle.js",
  "scripts": {
    "clean": "rimraf dist",
    "build:dir": "mkdirp dist",
    "build:html": "recursive-copy -w html dist",
    "build:preload": "recursive-copy -w app/preload.js dist/preload.js",
    "build:regex": "recursive-copy -w app/regex-patterns.json dist/regex-patterns.json",
    "build-assets": "npm run build:dir && npm run build:html && npm run build:regex",
    "build-dev": "npm run build-assets && webpack --mode development",
    "build-prod": "npm run build-assets && webpack --env prod --mode production",
    "build": "npm run build-prod",
    "watch": "npm run build-assets && webpack --mode development --watch",
    "start": "electron ./dist/main.bundle.js",
    "dev": "npm run build-dev && npm run start",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --publish=never",
    "dist:mac": "electron-builder --mac --publish=never",
    "dist:win": "electron-builder --win --publish=never",
    "dist:linux": "electron-builder --linux --publish=never"
  },
  "keywords": [
    "csv",
    "data",
    "combiner",
    "viewer",
    "electron",
    "duckdb"
  ],
  "author": "Abin Jacob <aj4abinjacob@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "@blueprintjs/core": "^4.20.2",
    "@blueprintjs/icons": "^4.16.0",
    "@blueprintjs/popover2": "^1.14.1",
    "@tanstack/react-virtual": "^3.13.19",
    "chrono-node": "^2.9.0",
    "duckdb": "^1.1.0",
    "electron-log": "^4.4.8",
    "lodash": "^4.17.21",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/lodash": "^4.17.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "css-loader": "^6.10.0",
    "electron": "^31.0.1",
    "electron-builder": "^24.13.3",
    "file-loader": "^6.2.0",
    "less": "^4.2.0",
    "less-loader": "^12.2.0",
    "mkdirp": "^3.0.1",
    "recursive-copy-cli": "^1.0.20",
    "resolve-url-loader": "^5.0.0",
    "rimraf": "^5.0.5",
    "sass": "^1.80.0",
    "sass-loader": "^14.2.0",
    "source-map-loader": "^5.0.0",
    "style-loader": "^3.3.4",
    "ts-loader": "^9.5.0",
    "typescript": "^5.4.0",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.4",
    "webpack-node-externals": "^3.0.0"
  },
  "build": {
    "appId": "com.abinjacob.chikku-parser",
    "productName": "Chikku Parser",
    "directories": {
      "buildResources": "res"
    },
    "files": [
      "dist/**/*",
      "node_modules"
    ],
    "fileAssociations": [
      {
        "ext": "csv",
        "name": "Comma Separated Values",
        "role": "Viewer"
      },
      {
        "ext": "tsv",
        "name": "Tab Separated Values",
        "role": "Viewer"
      },
      {
        "ext": "json",
        "name": "JSON File",
        "role": "Viewer"
      },
      {
        "ext": "parquet",
        "name": "Parquet File",
        "role": "Viewer"
      },
      {
        "ext": "xlsx",
        "name": "Excel Workbook",
        "role": "Viewer"
      },
      {
        "ext": "xls",
        "name": "Excel Spreadsheet",
        "role": "Viewer"
      }
    ],
    "publish": {
      "provider": "github"
    },
    "mac": {
      "identity": "-",
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "deb",
        "rpm",
        "tar.bz2"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false
    }
  }
}
